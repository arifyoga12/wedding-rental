{% extends 'layout/base.twig' %}

{% block content %}
<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl font-bold text-gray-800 mb-8">Pesanan Saya</h1>
    
    {% if orders %}
        <div class="space-y-6">
            {% for order in orders %}
                <div class="bg-white rounded-lg shadow-md p-6">
                    <div class="flex justify-between items-start mb-4">
                        <div>
                            <h3 class="text-lg font-semibold">Order #{{ order.id }}</h3>
                            <p class="text-gray-600">{{ order.created_at|date('F j, Y') }}</p>
                        </div>
                        <div class="text-right">
                            <span class="inline-block px-3 py-1 rounded-full text-sm font-medium
                                {{ order.status == 'pending' ? 'bg-yellow-100 text-yellow-800' : 
                                   order.status == 'confirmed' ? 'bg-blue-100 text-blue-800' :
                                   order.status == 'in-progress' ? 'bg-purple-100 text-purple-800' :
                                   'bg-green-100 text-green-800' }}">
                                {{ order.status|title }}
                            </span>
                        </div>
                    </div>
                    
                    <div class="grid md:grid-cols-2 gap-6 mb-4">
                        <div>
                            <h4 class="font-semibold mb-2">Detail Acara</h4>
                            <p class="text-gray-600">
                                <i class="fas fa-calendar mr-2"></i>{{ order.event_date|date('F j, Y') }}
                            </p>
                            <p class="text-gray-600">
                                <i class="fas fa-map-marker-alt mr-2"></i>{{ order.event_location }}
                            </p>
                        </div>
                        <div>
                            <h4 class="font-semibold mb-2">Status Pembayaran</h4>
                            <span class="inline-block px-3 py-1 rounded-full text-sm font-medium
                                {{ order.payment_status == 'none' ? 'bg-red-100 text-red-800' : 
                                   order.payment_status == 'dp' ? 'bg-yellow-100 text-yellow-800' :
                                   'bg-green-100 text-green-800' }}">
                                {{ order.payment_status == 'none' ? 'Belum Dibayar' : 
                                   order.payment_status == 'dp' ? 'DP' : 'Lunas' }}
                            </span>
                        </div>
                    </div>
                    
                    <div class="mb-4">
                        <h4 class="font-semibold mb-2">Item</h4>
                        <p class="text-gray-600">{{ order.items_summary }}</p>
                    </div>
                    
                    <div class="flex justify-between items-center pt-4 border-t">
                        <span class="text-xl font-bold">Total: Rp {{ order.total|number_format }}</span>
                        <div class="space-x-2">
                            {% if order.payment_status == 'none' %}
                                <button onclick="showPaymentModal('{{ order.id }}')" 
                                        class="bg-pink-500 text-white px-4 py-2 rounded hover:bg-pink-600 transition-colors">
                                    <i class="fas fa-credit-card mr-1"></i>Bayar Sekarang
                                </button>
                            {% endif %}
                        <button onclick="viewOrderDetail('{{ order.id }}')" 
                                class="border border-gray-300 text-gray-700 px-4 py-2 rounded hover:bg-gray-50 transition-colors">
                                <i class="fas fa-eye mr-1"></i>Lihat Detail
                            </button>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="text-center py-12">
            <i class="fas fa-clipboard-list text-gray-400 text-4xl mb-4"></i>
            <h3 class="text-xl font-semibold text-gray-600 mb-2">Belum ada pesanan</h3>
            <p class="text-gray-500 mb-6">Mulai belanja untuk membuat pesanan pertama Anda</p>
            <a href="{{ base_url }}/shop" class="bg-pink-500 text-white px-6 py-3 rounded-lg hover:bg-pink-600 transition-colors">
                Lihat Produk
            </a>
        </div>
    {% endif %}
</div>

{% block scripts %}
<script>
function viewOrderDetail(orderId) {
    console.log('Loading order detail for ID:', orderId);
    
    const modal = document.createElement('div');
    modal.className = 'fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50';
    modal.id = 'orderModal';
    modal.innerHTML = `
        <div class="bg-white rounded-lg p-6 max-w-2xl w-full mx-4 max-h-96 overflow-y-auto">
            <div class="flex justify-between items-center mb-4">
                <h3 class="text-xl font-semibold">Detail Pesanan #${orderId}</h3>
                <button onclick="closeModal()" class="text-gray-500 hover:text-gray-700">
                    <i class="fas fa-times text-xl"></i>
                </button>
            </div>
            <div id="orderDetailContent">
                <div class="text-center py-4">
                    <i class="fas fa-spinner fa-spin text-2xl text-pink-500"></i>
                    <p class="mt-2">Memuat detail pesanan...</p>
                </div>
            </div>
        </div>
    `;
    
    document.body.appendChild(modal);
    
    // Load detail pesanan via AJAX
    const baseUrl = '{{ base_url }}';
    fetch(`${baseUrl}/api/orders/detail?id=${orderId}`)
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                displayOrderDetail(data.order, data.items);
            } else {
                showOrderError(data.message || 'Gagal memuat detail pesanan');
            }
        })
        .catch(error => {
            console.error('Error loading order detail:', error);
            showOrderError('Terjadi kesalahan saat memuat detail pesanan');
        });
}

function displayOrderDetail(order, items) {
    const content = document.getElementById('orderDetailContent');
    if (!content) return;
    
    // Format tanggal
    const orderDate = new Date(order.created_at).toLocaleDateString('id-ID', {
        year: 'numeric',
        month: 'long',
        day: 'numeric'
    });
    
    const eventDate = new Date(order.event_date).toLocaleDateString('id-ID', {
        year: 'numeric',
        month: 'long',
        day: 'numeric'
    });
    
    // Format status
    const statusColors = {
        'pending': 'bg-yellow-100 text-yellow-800',
        'confirmed': 'bg-blue-100 text-blue-800',
        'in-progress': 'bg-purple-100 text-purple-800',
        'completed': 'bg-green-100 text-green-800'
    };
    
    const paymentStatusColors = {
        'none': 'bg-red-100 text-red-800',
        'dp': 'bg-yellow-100 text-yellow-800',
        'full': 'bg-green-100 text-green-800'
    };
    
    const paymentStatusText = {
        'none': 'Belum Dibayar',
        'dp': 'DP (Down Payment)',
        'full': 'Lunas'
    };
    
    // Generate items HTML
    let itemsHtml = '';
    let totalAmount = 0;
    
    items.forEach(item => {
        const itemTotal = parseFloat(item.price) * parseInt(item.quantity);
        totalAmount += itemTotal;
        
        itemsHtml += `
            <div class="flex items-center justify-between py-2 border-b border-gray-100 last:border-b-0">
                <div class="flex items-center">
                    <img src="${item.product_image || 'https://via.placeholder.com/50'}" 
                         alt="${item.product_name}" 
                         class="w-12 h-12 object-cover rounded mr-3">
                    <div>
                        <h5 class="font-medium text-gray-800">${item.product_name}</h5>
                        <p class="text-sm text-gray-500">Kategori: ${item.category}</p>
                        <p class="text-sm text-gray-600">Qty: ${item.quantity} x Rp ${parseInt(item.price).toLocaleString('id-ID')}</p>
                    </div>
                </div>
                <div class="text-right">
                    <p class="font-semibold text-pink-600">Rp ${itemTotal.toLocaleString('id-ID')}</p>
                </div>
            </div>
        `;
    });
    
    content.innerHTML = `
        <div class="space-y-6">
            <div class="grid md:grid-cols-2 gap-6">
                <div>
                    <h4 class="font-semibold mb-3 text-gray-800">Informasi Pesanan</h4>
                    <div class="space-y-2 text-sm">
                        <p><span class="font-medium">ID Pesanan:</span> #${order.id}</p>
                        <p><span class="font-medium">Tanggal Pesan:</span> ${orderDate}</p>
                        <p><span class="font-medium">Status:</span> 
                            <span class="inline-block px-2 py-1 rounded-full text-xs font-medium ${statusColors[order.status] || 'bg-gray-100 text-gray-800'}">
                                ${order.status.charAt(0).toUpperCase() + order.status.slice(1)}
                            </span>
                        </p>
                        <p><span class="font-medium">Status Pembayaran:</span> 
                            <span class="inline-block px-2 py-1 rounded-full text-xs font-medium ${paymentStatusColors[order.payment_status] || 'bg-gray-100 text-gray-800'}">
                                ${paymentStatusText[order.payment_status] || order.payment_status}
                            </span>
                        </p>
                    </div>
                </div>
                <div>
                    <h4 class="font-semibold mb-3 text-gray-800">Detail Acara</h4>
                    <div class="space-y-2 text-sm">
                        <p><span class="font-medium">Tanggal Acara:</span> ${eventDate}</p>
                        <p><span class="font-medium">Lokasi:</span></p>
                        <p class="text-gray-600 bg-gray-50 p-2 rounded text-xs">${order.event_location}</p>
                    </div>
                </div>
            </div>
            
            <div>
                <h4 class="font-semibold mb-3 text-gray-800">Item Pesanan</h4>
                <div class="bg-gray-50 rounded-lg p-4 max-h-48 overflow-y-auto">
                    ${itemsHtml}
                </div>
            </div>
            
            <div class="border-t pt-4">
                <div class="flex justify-between items-center mb-4">
                    <span class="text-lg font-semibold text-gray-800">Total Pembayaran:</span>
                    <span class="text-2xl font-bold text-pink-600">Rp ${totalAmount.toLocaleString('id-ID')}</span>
                </div>
                
                <div class="flex gap-3">
                    ${order.payment_status === 'none' ? `
                        <button onclick="showPaymentModal('${order.id}')" 
                                class="flex-1 bg-pink-500 text-white px-4 py-3 rounded-lg font-semibold hover:bg-pink-600 transition-colors">
                            <i class="fas fa-credit-card mr-2"></i>Bayar Sekarang
                        </button>
                    ` : ''}
                    <button onclick="contactSupport('${order.id}')" 
                            class="flex-1 border border-gray-300 text-gray-700 px-4 py-3 rounded-lg font-semibold hover:bg-gray-50 transition-colors">
                        <i class="fas fa-whatsapp mr-2"></i>Hubungi Support
                    </button>
                </div>
            </div>
        </div>
    `;
}

function showPaymentModal(orderId) {
    // Close existing modal first
    closeModal();
    
    const modal = document.createElement('div');
    modal.className = 'fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 p-4';
    modal.id = 'paymentModal';
    modal.innerHTML = `
        <div class="bg-white rounded-lg p-6 max-w-2xl w-full max-h-[90vh] overflow-y-auto">
            <div class="flex justify-between items-center mb-6">
                <h3 class="text-xl font-semibold">Pembayaran Pesanan #${orderId}</h3>
                <button onclick="closePaymentModal()" class="text-gray-500 hover:text-gray-700">
                    <i class="fas fa-times text-xl"></i>
                </button>
            </div>
            <div id="paymentContent">
                <div class="text-center py-4">
                    <i class="fas fa-spinner fa-spin text-2xl text-pink-500"></i>
                    <p class="mt-2">Memuat metode pembayaran...</p>
                </div>
            </div>
        </div>
    `;
    
    document.body.appendChild(modal);
    
    // Load payment methods
    loadPaymentMethods(orderId);
}

function loadPaymentMethods(orderId) {
    const baseUrl = '{{ base_url }}';
    
    Promise.all([
        fetch(`${baseUrl}/api/payment/methods`).then(r => r.json()),
        fetch(`${baseUrl}/api/orders/detail?id=${orderId}`).then(r => r.json())
    ])
    .then(([methodsResult, orderResult]) => {
        if (methodsResult.success && orderResult.success) {
            displayPaymentForm(orderId, methodsResult.payment_methods, orderResult.order);
        } else {
            showPaymentError('Gagal memuat data pembayaran');
        }
    })
    .catch(error => {
        console.error('Error loading payment data:', error);
        showPaymentError('Terjadi kesalahan saat memuat data');
    });
}

function displayPaymentForm(orderId, paymentMethods, order) {
    const content = document.getElementById('paymentContent');
    if (!content) return;
    
    const bankMethods = paymentMethods.filter(m => m.type === 'bank_transfer');
    const eWalletMethods = paymentMethods.filter(m => m.type === 'e_wallet');
    
    content.innerHTML = `
        <form id="paymentForm" class="space-y-6">
            <input type="hidden" name="order_id" value="${orderId}">
            
            <!-- Order Summary -->
            <div class="bg-gray-50 rounded-lg p-4">
                <h4 class="font-semibold mb-2">Ringkasan Pesanan</h4>
                <div class="flex justify-between items-center">
                    <span>Total Pembayaran:</span>
                    <span class="text-xl font-bold text-pink-600">Rp ${parseInt(order.total).toLocaleString('id-ID')}</span>
                </div>
                <div class="flex justify-between items-center text-sm text-gray-600 mt-1">
                    <span>Sudah Dibayar:</span>
                    <span>Rp ${parseInt(order.total_paid || 0).toLocaleString('id-ID')}</span>
                </div>
                <div class="flex justify-between items-center text-sm font-semibold border-t pt-2 mt-2">
                    <span>Sisa Pembayaran:</span>
                    <span class="text-pink-600">Rp ${parseInt(order.remaining_amount || order.total).toLocaleString('id-ID')}</span>
                </div>
            </div>
            
            <!-- Payment Type -->
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Jenis Pembayaran</label>
                <div class="space-y-2">
                    <label class="flex items-center">
                        <input type="radio" name="payment_type" value="full" checked class="mr-2">
                        <span>Bayar Lunas (Rp ${parseInt(order.remaining_amount || order.total).toLocaleString('id-ID')})</span>
                    </label>
                    <label class="flex items-center">
                        <input type="radio" name="payment_type" value="dp" class="mr-2">
                        <span>Bayar DP 50% (Rp ${parseInt((order.remaining_amount || order.total) * 0.5).toLocaleString('id-ID')})</span>
                    </label>
                </div>
            </div>
            
            <!-- Payment Method -->
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Metode Pembayaran</label>
                
                <!-- Payment Type Selection -->
                <div class="mb-6" x-data="{ selectedType: '' }">
                    <div class="grid grid-cols-2 gap-4 mb-4">
                        <!-- Bank Transfer Button -->
                        <button type="button" @click="selectedType = 'bank'" 
                                :class="selectedType === 'bank' ? 'bg-pink-500 text-white border-pink-500' : 'bg-white text-gray-700 border-gray-300 hover:bg-gray-50'"
                                class="flex flex-col items-center p-4 border-2 rounded-lg transition-all duration-200">
                            <i class="fas fa-university text-2xl mb-2"></i>
                            <span class="font-semibold">Transfer Bank</span>
                            <span class="text-xs opacity-75">BCA, Mandiri, BNI</span>
                        </button>
                        
                        <!-- E-Wallet Button -->
                        <button type="button" @click="selectedType = 'ewallet'" 
                                :class="selectedType === 'ewallet' ? 'bg-pink-500 text-white border-pink-500' : 'bg-white text-gray-700 border-gray-300 hover:bg-gray-50'"
                                class="flex flex-col items-center p-4 border-2 rounded-lg transition-all duration-200">
                            <i class="fas fa-mobile-alt text-2xl mb-2"></i>
                            <span class="font-semibold">E-Wallet</span>
                            <span class="text-xs opacity-75">GoPay, OVO, DANA</span>
                        </button>
                    </div>
                    
                    <!-- Bank Transfer Options -->
                    <div x-show="selectedType === 'bank'" x-transition class="space-y-3">
                        <h5 class="font-medium text-gray-800 flex items-center">
                            <i class="fas fa-university text-pink-500 mr-2"></i>
                            Pilih Rekening Bank
                        </h5>
                        <div class="grid grid-cols-1 gap-3">
                            ${bankMethods.map(method => `
                                <label class="flex items-center p-4 border-2 rounded-lg hover:bg-pink-50 hover:border-pink-200 cursor-pointer transition-all duration-200 group">
                                    <input type="radio" name="payment_method_id" value="${method.id}" class="mr-4 text-pink-500 focus:ring-pink-500">
                                    <div class="flex items-center flex-1">
                                        <div class="w-12 h-12 bg-gradient-to-br from-blue-500 to-blue-600 rounded-lg flex items-center justify-center mr-4">
                                            <span class="text-white font-bold text-sm">${method.bank_name.substring(5, 8).toUpperCase()}</span>
                                        </div>
                                        <div class="flex-1">
                                            <div class="font-semibold text-gray-800 group-hover:text-pink-600">${method.bank_name}</div>
                                            <div class="text-sm text-gray-600 font-mono">${method.account_number}</div>
                                            <div class="text-sm text-gray-500">a.n. ${method.account_name}</div>
                                        </div>
                                        <div class="text-pink-500 opacity-0 group-hover:opacity-100 transition-opacity">
                                            <i class="fas fa-check-circle text-xl"></i>
                                        </div>
                                    </div>
                                </label>
                            `).join('')}
                        </div>
                        
                        <!-- Bank Transfer Instructions -->
                        <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mt-4">
                            <h6 class="font-semibold text-blue-800 mb-2">
                                <i class="fas fa-info-circle mr-2"></i>Cara Transfer Bank
                            </h6>
                            <ol class="text-sm text-blue-700 space-y-1">
                                <li>1. Buka aplikasi mobile banking atau datang ke ATM</li>
                                <li>2. Pilih menu transfer ke rekening lain</li>
                                <li>3. Masukkan nomor rekening tujuan</li>
                                <li>4. Masukkan jumlah sesuai tagihan</li>
                                <li>5. Simpan bukti transfer dan upload di form ini</li>
                            </ol>
                        </div>
                    </div>
                    
                    <!-- E-Wallet Options -->
                    <div x-show="selectedType === 'ewallet'" x-transition class="space-y-3">
                        <h5 class="font-medium text-gray-800 flex items-center">
                            <i class="fas fa-mobile-alt text-pink-500 mr-2"></i>
                            Pilih E-Wallet
                        </h5>
                        <div class="grid grid-cols-1 gap-3">
                            ${eWalletMethods.map((method, index) => {
                                const colors = [
                                    'from-green-500 to-green-600', // GoPay
                                    'from-purple-500 to-purple-600', // OVO  
                                    'from-blue-500 to-blue-600' // DANA
                                ];
                                const icons = ['fas fa-motorcycle', 'fas fa-wallet', 'fas fa-coins'];
                                return `
                                    <label class="flex items-center p-4 border-2 rounded-lg hover:bg-pink-50 hover:border-pink-200 cursor-pointer transition-all duration-200 group">
                                        <input type="radio" name="payment_method_id" value="${method.id}" class="mr-4 text-pink-500 focus:ring-pink-500">
                                        <div class="flex items-center flex-1">
                                            <div class="w-12 h-12 bg-gradient-to-br ${colors[index % colors.length]} rounded-lg flex items-center justify-center mr-4">
                                                <i class="${icons[index % icons.length]} text-white text-lg"></i>
                                            </div>
                                            <div class="flex-1">
                                                <div class="font-semibold text-gray-800 group-hover:text-pink-600">${method.bank_name}</div>
                                                <div class="text-sm text-gray-600">${method.account_number}</div>
                                                <div class="text-sm text-gray-500">a.n. ${method.account_name}</div>
                                            </div>
                                            <div class="text-pink-500 opacity-0 group-hover:opacity-100 transition-opacity">
                                                <i class="fas fa-check-circle text-xl"></i>
                                            </div>
                                        </div>
                                    </label>
                                `;
                            }).join('')}
                        </div>
                        
                        <!-- E-Wallet Instructions -->
                        <div class="bg-green-50 border border-green-200 rounded-lg p-4 mt-4">
                            <h6 class="font-semibold text-green-800 mb-2">
                                <i class="fas fa-mobile-alt mr-2"></i>Cara Transfer E-Wallet
                            </h6>
                            <ol class="text-sm text-green-700 space-y-1">
                                <li>1. Buka aplikasi e-wallet pilihan Anda</li>
                                <li>2. Pilih menu transfer atau kirim uang</li>
                                <li>3. Masukkan nomor tujuan atau scan QR code</li>
                                <li>4. Masukkan jumlah sesuai tagihan</li>
                                <li>5. Screenshot bukti transfer dan upload di form ini</li>
                            </ol>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Payment Details -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Nama Pengirim</label>
                    <input type="text" name="sender_name" required 
                           class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-pink-500">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Tanggal Transfer</label>
                    <input type="date" name="transfer_date" required 
                           class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-pink-500">
                </div>
            </div>
            
            <!-- Upload Proof -->
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Bukti Pembayaran</label>
                <input type="file" name="proof_image" accept="image/*" required 
                       class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-pink-500">
                <p class="text-xs text-gray-500 mt-1">Upload foto bukti transfer (JPG, PNG, max 5MB)</p>
            </div>
            
            <!-- Notes -->
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Catatan (Opsional)</label>
                <textarea name="notes" rows="3" 
                          placeholder="Catatan tambahan untuk pembayaran..."
                          class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-pink-500"></textarea>
            </div>
            
            <!-- Submit Button -->
            <div class="flex gap-3">
                <button type="button" onclick="closePaymentModal()" 
                        class="flex-1 border border-gray-300 text-gray-700 px-4 py-3 rounded-lg font-semibold hover:bg-gray-50 transition-colors">
                    Batal
                </button>
                <button type="submit" id="submitPaymentBtn"
                        class="flex-1 bg-pink-500 text-white px-4 py-3 rounded-lg font-semibold hover:bg-pink-600 transition-colors">
                    <i class="fas fa-upload mr-2"></i>Upload Bukti Pembayaran
                </button>
            </div>
        </form>
    `;
    
    // Set default date to today
    const today = new Date().toISOString().split('T')[0];
    document.querySelector('input[name="transfer_date"]').value = today;
    
    // Handle form submission
    document.getElementById('paymentForm').addEventListener('submit', handlePaymentSubmit);
    
    // Handle payment type change
    document.querySelectorAll('input[name="payment_type"]').forEach(radio => {
        radio.addEventListener('change', function() {
            updatePaymentAmount(order);
        });
    });
    
    // Add form validation
    addPaymentFormValidation();
}

function updatePaymentAmount(order) {
    const paymentType = document.querySelector('input[name="payment_type"]:checked').value;
    const remainingAmount = order.remaining_amount || order.total;
    const amount = paymentType === 'dp' ? remainingAmount * 0.5 : remainingAmount;
    
    // Update display if needed
    console.log('Payment amount updated:', amount);
}

function handlePaymentSubmit(e) {
    e.preventDefault();
    
    const formData = new FormData(e.target);
    const paymentType = formData.get('payment_type');
    const paymentMethodId = formData.get('payment_method_id');
    const senderName = formData.get('sender_name');
    const transferDate = formData.get('transfer_date');
    const proofImage = formData.get('proof_image');
    const notes = formData.get('notes');
    const orderId = formData.get('order_id');
    
    // Validation
    if (!paymentMethodId) {
        showNotification('Silakan pilih metode pembayaran terlebih dahulu', 'error');
        return;
    }
    
    if (!senderName || !transferDate || !proofImage) {
        showNotification('Lengkapi semua field yang diperlukan', 'error');
        return;
    }
    
    // Validate file size (max 5MB)
    if (proofImage.size > 5 * 1024 * 1024) {
        showNotification('Ukuran file maksimal 5MB', 'error');
        return;
    }
    
    // Validate file type
    const allowedTypes = ['image/jpeg', 'image/jpg', 'image/png'];
    if (!allowedTypes.includes(proofImage.type)) {
        showNotification('Format file harus JPG atau PNG', 'error');
        return;
    }
    
    // Show loading
    const submitBtn = e.target.querySelector('button[type="submit"]');
    const originalText = submitBtn.innerHTML;
    submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>Mengupload...';
    submitBtn.disabled = true;
    
    // Convert image to base64 (simplified for demo)
    const reader = new FileReader();
    reader.onload = function(event) {
        const base64Image = event.target.result;
        
        // Get order total for amount calculation
        fetch('{{ base_url }}/api/orders/detail?id=' + orderId)
            .then(response => response.json())
            .then(orderData => {
                if (orderData.success) {
                    const order = orderData.order;
                    const remainingAmount = order.remaining_amount || order.total;
                    const amount = paymentType === 'dp' ? remainingAmount * 0.5 : remainingAmount;
                    
                    // Submit payment
                    const paymentData = {
                        order_id: orderId,
                        payment_method_id: paymentMethodId,
                        amount: amount,
                        payment_type: paymentType,
                        sender_name: senderName,
                        transfer_date: transferDate,
                        proof_image: base64Image,
                        notes: notes
                    };
                    
                    return fetch('{{ base_url }}/api/payment/upload', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(paymentData)
                    });
                } else {
                    throw new Error('Gagal memuat data pesanan');
                }
            })
            .then(response => response.json())
            .then(result => {
                if (result.success) {
                    showNotification('Bukti pembayaran berhasil diupload! Menunggu verifikasi admin.', 'success');
                    closePaymentModal();
                    // Refresh page to show updated status
                    setTimeout(() => {
                        location.reload();
                    }, 2000);
                } else {
                    showNotification(result.message || 'Gagal mengupload bukti pembayaran', 'error');
                }
            })
            .catch(error => {
                console.error('Payment upload error:', error);
                showNotification('Terjadi kesalahan saat mengupload', 'error');
            })
            .finally(() => {
                submitBtn.innerHTML = originalText;
                submitBtn.disabled = false;
            });
    };
    
    reader.readAsDataURL(proofImage);
}

function addPaymentFormValidation() {
    // Real-time validation for payment method selection
    document.querySelectorAll('input[name="payment_method_id"]').forEach(radio => {
        radio.addEventListener('change', function() {
            // Remove any previous error styling
            document.querySelectorAll('.payment-method-error').forEach(el => el.remove());
            
            // Enable submit button if method is selected
            const submitBtn = document.getElementById('submitPaymentBtn');
            if (submitBtn) {
                submitBtn.disabled = false;
                submitBtn.classList.remove('opacity-50', 'cursor-not-allowed');
            }
        });
    });
    
    // File upload preview
    const fileInput = document.querySelector('input[name="proof_image"]');
    if (fileInput) {
        fileInput.addEventListener('change', function(e) {
            const file = e.target.files[0];
            if (file) {
                // Remove previous preview
                const existingPreview = document.getElementById('imagePreview');
                if (existingPreview) {
                    existingPreview.remove();
                }
                
                // Create preview
                const reader = new FileReader();
                reader.onload = function(event) {
                    const preview = document.createElement('div');
                    preview.id = 'imagePreview';
                    preview.className = 'mt-2 p-2 border rounded-lg bg-gray-50';
                    preview.innerHTML = `
                        <div class="flex items-center space-x-3">
                            <img src="${event.target.result}" alt="Preview" class="w-16 h-16 object-cover rounded">
                            <div class="flex-1">
                                <p class="text-sm font-medium text-gray-800">${file.name}</p>
                                <p class="text-xs text-gray-500">${(file.size / 1024 / 1024).toFixed(2)} MB</p>
                            </div>
                            <button type="button" onclick="clearFilePreview()" class="text-red-500 hover:text-red-700">
                                <i class="fas fa-times"></i>
                            </button>
                        </div>
                    `;
                    fileInput.parentNode.appendChild(preview);
                };
                reader.readAsDataURL(file);
            }
        });
    }
}

function clearFilePreview() {
    const preview = document.getElementById('imagePreview');
    const fileInput = document.querySelector('input[name="proof_image"]');
    
    if (preview) {
        preview.remove();
    }
    
    if (fileInput) {
        fileInput.value = '';
    }
}

function showPaymentError(message) {
    const content = document.getElementById('paymentContent');
    if (!content) return;
    
    content.innerHTML = `
        <div class="text-center py-8">
            <i class="fas fa-exclamation-triangle text-red-500 text-3xl mb-4"></i>
            <h4 class="text-lg font-semibold text-gray-800 mb-2">Gagal Memuat Pembayaran</h4>
            <p class="text-gray-600 mb-4">${message}</p>
            <button onclick="closePaymentModal()" 
                    class="bg-gray-500 text-white px-4 py-2 rounded hover:bg-gray-600 transition-colors">
                Tutup
            </button>
        </div>
    `;
}

function closePaymentModal() {
    const modal = document.getElementById('paymentModal');
    if (modal && modal.parentNode) {
        document.body.removeChild(modal);
    }
}

function showOrderError(message) {
    const content = document.getElementById('orderDetailContent');
    if (!content) return;
    
    content.innerHTML = `
        <div class="text-center py-8">
            <i class="fas fa-exclamation-triangle text-red-500 text-3xl mb-4"></i>
            <h4 class="text-lg font-semibold text-gray-800 mb-2">Gagal Memuat Detail</h4>
            <p class="text-gray-600 mb-4">${message}</p>
            <button onclick="closeModal()" 
                    class="bg-gray-500 text-white px-4 py-2 rounded hover:bg-gray-600 transition-colors">
                Tutup
            </button>
        </div>
    `;
}

function contactSupport(orderId) {
    const message = encodeURIComponent(`Halo, saya membutuhkan bantuan terkait pesanan #${orderId}. Mohon bantuannya.`);
    const whatsappUrl = `https://wa.me/6281234567890?text=${message}`;
    window.open(whatsappUrl, '_blank');
}

function closeModal() {
    const modal = document.getElementById('orderModal');
    if (modal && modal.parentNode) {
        document.body.removeChild(modal);
    }
}

// Close modal when clicking outside
document.addEventListener('click', function(e) {
    if (e.target.id === 'orderModal') {
        closeModal();
    }
});

// Close modal with Escape key
document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
        const content = document.getElementById('orderDetailContent');
        if (content) {
            closeModal();
        }
    }
});
</script>
