{% extends 'layout/base.twig' %}

{% block content %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Header -->
    <div class="mb-8">
        <h1 class="text-3xl font-bold text-gray-800 mb-4">Belanja Dekorasi Pernikahan</h1>
        <p class="text-gray-600">Temukan produk dan layanan terbaik untuk pernikahan impian Anda</p>
    </div>

    <!-- Search and Filter -->
    <div class="mb-8 bg-white p-6 rounded-lg shadow-md">
        <form method="GET" action="{{ base_url }}/shop" class="flex flex-col md:flex-row gap-4">
            <div class="flex-1">
                <input type="text" name="search" value="{{ search_term }}" 
                       placeholder="Cari produk atau vendor..." 
                       class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-pink-500">
            </div>
            <div>
                <select name="category" class="px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-pink-500">
                    <option value="">Semua Kategori</option>
                    {% for category in categories %}
                        <option value="{{ category.id }}" {{ current_category == category.id ? 'selected' : '' }}>
                            {{ category.icon }} {{ category.name }}
                        </option>
                    {% endfor %}
                </select>
            </div>
            <button type="submit" class="bg-pink-500 text-white px-6 py-2 rounded-md hover:bg-pink-600 transition-colors">
                <i class="fas fa-search mr-2"></i>Cari
            </button>
        </form>
    </div>

    <!-- Category Filter Pills -->
    <div class="mb-8">
        <div class="flex flex-wrap gap-2">
            <a href="{{ base_url }}/shop" 
               class="px-4 py-2 rounded-full text-sm font-medium transition-colors {{ current_category == '' ? 'bg-pink-500 text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200' }}">
                Semua
            </a>
            {% for category in categories %}
                <a href="{{ base_url }}/shop?category={{ category.id }}" 
                   class="px-4 py-2 rounded-full text-sm font-medium transition-colors {{ current_category == category.id ? 'bg-pink-500 text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200' }}">
                    {{ category.icon }} {{ category.name }}
                </a>
            {% endfor %}
        </div>
    </div>

    <!-- Results Info -->
    {% if search_term or current_category %}
        <div class="mb-6">
            <p class="text-gray-600">
                {% if search_term %}
                    Hasil pencarian untuk "<strong>{{ search_term }}</strong>"
                    {% if current_category %}
                        dalam kategori <strong>{{ categories|filter(c => c.id == current_category)|first.name }}</strong>
                    {% endif %}
                {% else %}
                    Menampilkan produk kategori <strong>{{ categories|filter(c => c.id == current_category)|first.name }}</strong>
                {% endif %}
                - {{ products|length }} produk ditemukan
            </p>
        </div>
    {% endif %}

    <!-- Products Grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        {% for product in products %}
            <div class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition-shadow">
                <div class="relative">
                    <img src="{{ product.image }}" alt="{{ product.name }}" class="w-full h-48 object-cover">
                    <div class="absolute top-2 left-2">
                        <span class="bg-pink-500 text-white text-xs px-2 py-1 rounded-full">
                            {{ product.category|title }}
                        </span>
                    </div>
                    {% if not product.available %}
                        <div class="absolute inset-0 bg-black bg-opacity-50 flex items-center justify-center">
                            <span class="bg-red-500 text-white px-3 py-1 rounded-full text-sm font-medium">
                                Tidak Tersedia
                            </span>
                        </div>
                    {% endif %}
                </div>
                
                <div class="p-4">
                    <div class="flex items-center justify-between mb-2">
                        <h3 class="text-lg font-semibold text-gray-800 truncate">{{ product.name }}</h3>
                        <div class="flex items-center">
                            <i class="fas fa-star text-yellow-400 text-sm mr-1"></i>
                            <span class="text-sm text-gray-600">{{ product.rating }}</span>
                        </div>
                    </div>
                    
                    <p class="text-gray-600 text-sm mb-2">{{ product.vendor }}</p>
                    <p class="text-gray-600 text-sm mb-4 line-clamp-2">{{ product.description }}</p>
                    
                    <div class="flex justify-between items-center">
                        <span class="text-xl font-bold text-pink-500">
                            Rp {{ product.price|number_format }}
                        </span>
                        {% if product.available %}
                            <button onclick="addToCart({{ product.id }})" 
                                    class="bg-pink-500 text-white px-4 py-2 rounded hover:bg-pink-600 transition-colors text-sm">
                                <i class="fas fa-cart-plus mr-1"></i>Tambah
                            </button>
                        {% else %}
                            <button disabled 
                                    class="bg-gray-300 text-gray-500 px-4 py-2 rounded cursor-not-allowed text-sm">
                                Tidak Tersedia
                            </button>
                        {% endif %}
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col-span-full text-center py-12">
                <i class="fas fa-search text-gray-400 text-4xl mb-4"></i>
                <h3 class="text-xl font-semibold text-gray-600 mb-2">Produk tidak ditemukan</h3>
                <p class="text-gray-500 mb-6">
                    {% if search_term %}
                        Coba kata kunci lain atau ubah filter pencarian Anda
                    {% else %}
                        Belum ada produk dalam kategori ini
                    {% endif %}
                </p>
                <a href="{{ base_url }}/shop" class="bg-pink-500 text-white px-6 py-3 rounded-lg hover:bg-pink-600 transition-colors">
                    Lihat Semua Produk
                </a>
            </div>
        {% endfor %}
    </div>

    <!-- Load More / Pagination (if needed) -->
    {% if products|length >= 12 %}
        <div class="text-center mt-12">
            <button class="bg-gray-100 text-gray-700 px-8 py-3 rounded-lg hover:bg-gray-200 transition-colors">
                Muat Lebih Banyak
            </button>
        </div>
    {% endif %}
</div>

<style>
.line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
}
</style>
{% endblock %}