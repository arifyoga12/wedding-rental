                        @media print {
                            body { margin: 0; }
                            .no-print { display: none; }
                        }
                    </style>
                </head>
                <body>
                    <div class="header">
                        <div class="company-name">SewaDekorasi</div>
                        <div class="report-title">Laporan Produk Terlaris</div>
                        <div class="period">Periode: ${startDate} - ${endDate}</div>
                    </div>
                    
                    <table>
                        <thead>
                            <tr>
                                <th>No</th>
                                <th>Nama Produk</th>
                                <th>Kategori</th>
                                <th>Jumlah Terjual</th>
                                <th>Total Revenue</th>
                            </tr>
                        </thead>
                        <tbody>
                            ${productsHtml}
                        </tbody>
                    </table>
                    
                    <div class="footer">
                        <p>Dicetak pada: ${new Date().toLocaleString('id-ID')}</p>
                        <p>SewaDekorasi - Sistem Manajemen Wedding Rental</p>
                    </div>
                </body>
                </html>
            `;
