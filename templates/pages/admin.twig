                        .header { text-align: center; margin-bottom: 30px; }
                        .company-name { font-size: 24px; font-weight: bold; color: #e91e63; }
                        .report-title { font-size: 18px; margin: 10px 0; }
                        .period { font-size: 14px; color: #666; }
                        .summary { margin: 20px 0; }
                        .summary-item { display: flex; justify-content: space-between; padding: 10px 0; border-bottom: 1px solid #eee; }
                        .summary-item:last-child { border-bottom: 2px solid #e91e63; font-weight: bold; }
                        .footer { margin-top: 40px; text-align: center; font-size: 12px; color: #666; }
                        @media print {
                            body { margin: 0; }
                            .no-print { display: none; }
                        }
                    </style>
                </head>
                <body>
                    <div class="header">
                        <div class="company-name">SewaDekorasi</div>
                        <div class="report-title">Laporan Penjualan</div>
                        <div class="period">Periode: ${startDate} - ${endDate}</div>
                    </div>
                    
                    <div class="summary">
                        <div class="summary-item">
                            <span>Total Pesanan:</span>
                            <span>${this.reportData.totalOrders || 0}</span>
                        </div>
                        <div class="summary-item">
                            <span>Total Penjualan:</span>
                            <span>Rp ${(this.reportData.totalSales || 0).toLocaleString('id-ID')}</span>
                        </div>
                        <div class="summary-item">
                            <span>Rata-rata per Pesanan:</span>
                            <span>Rp ${(this.reportData.averageOrder || 0).toLocaleString('id-ID')}</span>
                        </div>
                    </div>
                    
                    <div class="footer">
                        <p>Dicetak pada: ${new Date().toLocaleString('id-ID')}</p>
                        <p>SewaDekorasi - Sistem Manajemen Wedding Rental</p>
                    </div>
                </body>
                </html>
            `;
        },

        generateProductReportHTML() {
            const startDate = new Date(this.reportStartDate).toLocaleDateString('id-ID');
            const endDate = new Date(this.reportEndDate).toLocaleDateString('id-ID');
            
            let productsHtml = '';
            if (this.reportData.topProducts && this.reportData.topProducts.length > 0) {
                this.reportData.topProducts.forEach((product, index) => {
                    productsHtml += `
                        <tr>
                            <td>${index + 1}</td>
                            <td>${product.name}</td>
                            <td>${product.category}</td>
                            <td>${product.total_sold}</td>
                            <td>Rp ${parseInt(product.total_revenue).toLocaleString('id-ID')}</td>
                        </tr>
                    `;
                });
            } else {
                productsHtml = '<tr><td colspan="5" style="text-align: center;">Tidak ada data produk</td></tr>';
            }
            
            return `
                <!DOCTYPE html>
                <html>
                <head>
                    <title>Laporan Produk Terlaris</title>
                    <style>
                        body { font-family: Arial, sans-serif; margin: 20px; }
